APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=
# DB_DUMP_BINARY_PATH=/opt/homebrew/opt/mysql-client/bin

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CCR_HEAVY_QUEUE_ENABLED=true
CCR_HEAVY_QUEUE_NAME=ccr-heavy
CCR_HEAVY_PENDING_TTL_SECONDS=300
CCR_HEAVY_COOLDOWN_SECONDS=45
CCR_HEAVY_LOCK_SECONDS=600
CCR_HEAVY_PREVIEW_INLINE_FALLBACK=true
CCR_HEAVY_WORD_INLINE_FALLBACK=true
CCR_HEAVY_PARTS_INLINE_FALLBACK=true
ENGINE_PREVIEW_TIMEOUT_SECONDS=120
SEAT_PREVIEW_TIMEOUT_SECONDS=120
ENGINE_PREVIEW_MAX_DOCX_BYTES=62914560
SEAT_PREVIEW_MAX_DOCX_BYTES=62914560
ENGINE_PREVIEW_MAX_PDF_BYTES=94371840
SEAT_PREVIEW_MAX_PDF_BYTES=94371840
SOFFICE_BINARY=
CCR_NOTIFY_MAIL_ENABLED=true
CCR_NOTIFY_WEB_PUSH_ENABLED=false
CCR_NOTIFY_QUEUE_NAME=ccr-notify
CCR_NOTIFY_COOLDOWN_SECONDS=8
CCR_NOTIFY_LOCK_SECONDS=120
CCR_NOTIFY_MAIL_SUBJECT_PREFIX=[CCR-RNF]
CCR_NOTIFY_MAIL_ALLOW_LOCAL_TEST=false
CCR_NOTIFY_MAIL_GLOBAL_RECIPIENTS_ENABLED=true
CCR_NOTIFY_MAIL_GLOBAL_MAX_RECIPIENTS=40
CCR_NOTIFY_LOGO_URL=
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_VAPID_SUBJECT=mailto:admin@example.com
WEB_PUSH_TTL_SECONDS=300
WEB_PUSH_URGENCY=normal
WEB_PUSH_MAX_FAILURES=3

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
HORIZON_PATH=horizon
SCHEDULE_HORIZON_SNAPSHOT=false
SCHEDULE_BACKUPS=false
SCHEDULE_DRAFT_PRUNE=true
CCR_DRAFT_RETENTION_DAYS=30
SCHEDULE_TRASH_PURGE=true
SCHEDULE_WEB_PUSH_PRUNE=true
WEB_PUSH_SUBSCRIPTION_RETENTION_DAYS=90

MAIL_MAILER=smtp
MAIL_SCHEME=smtps
MAIL_HOST=srv181.niagahoster.com
MAIL_PORT=465
MAIL_USERNAME=ccr-notify@rnadhfathan.com
MAIL_PASSWORD=
MAIL_TIMEOUT=15
MAIL_TLS_VERIFY_PEER=true
MAIL_TLS_VERIFY_PEER_NAME=true
MAIL_TLS_ALLOW_SELF_SIGNED=false
MAIL_FROM_ADDRESS="ccr-notify@rnadhfathan.com"
MAIL_FROM_NAME="${APP_NAME}"
BACKUP_MAIL_TO="hello@example.com"
BACKUP_ARCHIVE_PASSWORD=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
